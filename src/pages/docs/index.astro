---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BookOpen, ExternalLink, FileCode2, FolderOpen, Palette, Wrench } from "lucide-static";

const formatPath = (path) =>
  path
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll(" ", "&nbsp;")
    .replaceAll("\\", "\\<wbr>")
    .replaceAll("/", "/<wbr>");

const configPaths = [
  {
    platform: "Linux / BSD",
    primary: "~/.config/elio/config.toml",
    secondary: "$XDG_CONFIG_HOME/elio/config.toml",
  },
  {
    platform: "macOS",
    primary: "~/Library/Application Support/elio/config.toml",
  },
  {
    platform: "Windows",
    primary: "%APPDATA%\\elio\\config.toml",
  },
];

const themePaths = [
  {
    platform: "Linux / BSD",
    primary: "~/.config/elio/theme.toml",
    secondary: "$XDG_CONFIG_HOME/elio/theme.toml",
  },
  {
    platform: "macOS",
    primary: "~/Library/Application Support/elio/theme.toml",
  },
  {
    platform: "Windows",
    primary: "%APPDATA%\\elio\\theme.toml",
  },
];

const configSections = [
  {
    name: "[ui]",
    body: "Startup options like top bar, hidden files, grid view, and grid zoom.",
  },
  {
    name: "[places]",
    body: "Pinned sidebar entries and whether the Devices section stays visible.",
  },
  {
    name: "[layout.panes]",
    body: "Relative pane widths for Places, Files, and Preview.",
  },
  {
    name: "[keys]",
    body: "Single-character overrides for browser action keys.",
  },
];

const themeSections = [
  {
    name: "[palette]",
    body: "App-wide colors for chrome, panels, borders, text, and selection.",
  },
  {
    name: "[preview.code]",
    body: "Syntax colors for code previews.",
  },
  {
    name: "[classes.<name>]",
    body: "Default icon and color for a file class.",
  },
  {
    name: "[extensions.<ext>]",
    body: "Overrides by file extension.",
  },
  {
    name: '[files."name"]',
    body: "Overrides by exact filename.",
  },
  {
    name: '[directories."name"]',
    body: "Overrides by exact directory name.",
  },
];

const builtInClasses = [
  "directory",
  "code",
  "config",
  "document",
  "license",
  "image",
  "audio",
  "video",
  "archive",
  "font",
  "data",
  "file",
];

const referenceLinks = [
  {
    title: "Example config",
    body: "Annotated config for UI, Places, layout, and keys.",
    hint: "Setup",
    href: "https://github.com/elio-fm/elio/blob/main/examples/config.toml",
    icon: FileCode2,
    tone: "blue",
  },
  {
    title: "Default theme",
    body: "Built-in theme with palette, preview, classes, and overrides.",
    hint: "Theme",
    href: "https://github.com/elio-fm/elio/blob/main/assets/themes/default/theme.toml",
    icon: Palette,
    tone: "violet",
  },
  {
    title: "Bundled themes",
    body: "Copyable themes with screenshots.",
    hint: "Inspiration",
    href: "https://github.com/elio-fm/elio/tree/main/examples/themes",
    icon: FolderOpen,
    tone: "amber",
  },
  {
    title: "Previews and tools",
    body: "Preview coverage, image support, and optional tools.",
    hint: "Tools",
    href: "https://github.com/elio-fm/elio#optional-tools",
    icon: Wrench,
    tone: "mint",
  },
  {
    title: "Full README",
    body: "Install, workflow, previews, config, and theming.",
    hint: "Overview",
    href: "https://github.com/elio-fm/elio#readme",
    icon: BookOpen,
    tone: "slate",
  },
];
---

<BaseLayout
  title="elio docs"
  description="Quick reference for elio config files, theme files, and the main project docs."
>
  <div class="docs-page">
    <section class="page-intro docs-intro">
      <div class="container">
        <div class="page-lead">
          <p class="eyebrow">DOCS</p>
          <h1>elio docs</h1>
          <p>
            A quick reference for the files you edit most and what each one controls.
          </p>

          <nav class="docs-jump" aria-label="Docs sections">
            <a href="#paths">Paths</a>
            <a href="#config">Config</a>
            <a href="#theme">Theme</a>
            <a href="#reference">Reference</a>
          </nav>
        </div>
      </div>
    </section>

    <section class="section docs-section" id="paths">
      <div class="container">
        <div class="docs-section-heading">
          <p class="eyebrow">FILES</p>
          <h2 class="docs-section-title">Paths</h2>
          <p>elio uses two config files: <code>config.toml</code> and <code>theme.toml</code></p>
        </div>

        <div class="docs-two-up">
          <article class="doc-card docs-card-tight">
            <h3>Config file</h3>
            <table class="docs-table">
              <tbody>
                {
                  configPaths.map((entry) => (
                    <tr>
                      <th scope="row">{entry.platform}</th>
                      <td>
                        <code class="docs-path-code" set:html={formatPath(entry.primary)}></code>
                        {entry.secondary && <span class="docs-secondary-path"><code class="docs-path-code" set:html={formatPath(entry.secondary)}></code></span>}
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
            <p class="docs-note">
              Use this file for startup behavior, Places, layout, and key overrides.
            </p>
          </article>

          <article class="doc-card docs-card-tight">
            <h3>Theme file</h3>
            <table class="docs-table">
              <tbody>
                {
                  themePaths.map((entry) => (
                    <tr>
                      <th scope="row">{entry.platform}</th>
                      <td>
                        <code class="docs-path-code" set:html={formatPath(entry.primary)}></code>
                        {entry.secondary && <span class="docs-secondary-path"><code class="docs-path-code" set:html={formatPath(entry.secondary)}></code></span>}
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
            <p class="docs-note">
              Theme files layer on top of the built-in defaults, so you only need to set the values you want to change.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section docs-section" id="config">
      <div class="container">
        <div class="docs-section-heading">
          <p class="eyebrow">CONFIG</p>
          <h2 class="docs-section-title">What goes in config.toml</h2>
        </div>

        <article class="doc-card docs-detail-card">
          <div class="docs-detail-grid">
            <section class="docs-detail-block">
              <p class="docs-block-label">Sections</p>
              <ul class="docs-list">
                {
                  configSections.map((section) => (
                    <li>
                      <code>{section.name}</code>
                      <span>{section.body}</span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="docs-detail-block">
              <p class="docs-block-label">Rules</p>
              <ul class="docs-list">
                <li>
                  <span>Leave a section out to keep the built-in default behavior.</span>
                </li>
                <li>
                  <span>
                    <code>grid_zoom</code> is clamped to <code>0</code>, <code>1</code>, or <code>2</code>.
                  </span>
                </li>
                <li>
                  <span>
                    <code>places.entries</code> can use built-ins like <code>downloads</code> or custom paths starting with <code>~/</code>.
                  </span>
                </li>
                <li>
                  <span>
                    In <code>[layout.panes]</code>, <code>places = 0</code> hides Places and <code>preview = 0</code> hides Preview, but <code>files</code> must stay above <code>0</code>.
                  </span>
                </li>
              </ul>
            </section>
          </div>
        </article>
      </div>
    </section>

    <section class="section docs-section" id="theme">
      <div class="container">
        <div class="docs-section-heading">
          <p class="eyebrow">THEME</p>
          <h2 class="docs-section-title">What goes in theme.toml</h2>
        </div>

        <article class="doc-card docs-detail-card">
          <div class="docs-detail-grid">
            <section class="docs-detail-block">
              <p class="docs-block-label">Sections</p>
              <ul class="docs-list">
                {
                  themeSections.map((section) => (
                    <li>
                      <code>{section.name}</code>
                      <span>{section.body}</span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="docs-detail-block">
              <p class="docs-block-label">Rules</p>
              <ul class="docs-list">
                <li>
                  <span>
                    Exact filename and directory rules win over extension rules, and extension rules win over class defaults.
                  </span>
                </li>
                <li>
                  <span>Matching is case-insensitive.</span>
                </li>
                <li>
                  <span>Invalid theme files fall back to the built-in defaults.</span>
                </li>
                <li>
                  <span>Built-in classes</span>
                  <div class="docs-tag-row">
                    {builtInClasses.map((item) => <code>{item}</code>)}
                  </div>
                </li>
              </ul>
            </section>
          </div>
        </article>
      </div>
    </section>

    <section class="section docs-section" id="reference">
      <div class="container">
        <div class="docs-section-heading">
          <p class="eyebrow">REFERENCE</p>
          <h2 class="docs-section-title">Open the full reference</h2>
          <p>Use this page for the short version, then open the exact file or guide you need.</p>
        </div>

        <div class="docs-link-grid">
          {
            referenceLinks.map((link) => (
              <a
                class="docs-link-card"
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noreferrer" : undefined}
              >
                <div class="docs-link-top">
                  <span class={`docs-link-icon docs-link-icon--${link.tone}`} aria-hidden="true" set:html={link.icon}></span>
                  <span class="docs-link-hint">{link.hint}</span>
                </div>
                <h3>{link.title}</h3>
                <p>{link.body}</p>
                <span class="docs-link-more">
                  Open reference
                  <span class="docs-link-arrow" aria-hidden="true" set:html={ExternalLink}></span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
