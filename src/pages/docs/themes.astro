---
import DocsLayout from "../../layouts/DocsLayout.astro";
import Prism from "prismjs";
import "prismjs/components/prism-toml.js";
import { Check, Copy } from "lucide-static";
import { builtInClasses, formatPath, themePaths, themeSections } from "../../data/docs.js";
import { themeShots } from "../../data/site.js";

const themeSlug = (name) => name.toLowerCase().replaceAll(" ", "-");
const highlightToml = (code) => Prism.highlight(code, Prism.languages.toml, "toml");

const paletteSnippet = `# Colors accept #rrggbb, ansi-blue, indexed-12, none, or transparent.
[palette]
# App surfaces
bg = "#050505"               # page background
chrome = "#0c0c0c"           # top/outer chrome
chrome_alt = "#101010"       # alternate chrome surfaces

panel = "#121212"            # file/preview panels
panel_alt = "#0f0f0f"        # alternate panels
surface = "#161616"          # cards, inputs, overlays
elevated = "#1d1d1d"         # raised overlay surfaces

border = "#303030"           # pane/card borders
path_bg = "#111111"          # path bar background

# Text
text = "#e7edf5"             # primary text
muted = "#8c97a8"            # secondary text
chip_text = "#0c0c0c"        # text on bright chips

# Controls and states
accent = "#7aaeff"           # focused controls and links
accent_soft = "#1a2740"      # subtle accent backgrounds
accent_text = "#eef4ff"      # text on accent surfaces
selected_bg = "#243758"      # selected row background
selected_border = "#9cbcff"  # selected pane border

# Status markers
selection_bar = "#ffb24a"    # selected/marked item bar
yank_bar = "ansi-green"      # copied item bar
cut_bar = "ansi-red"         # cut item bar
progress_bar = "#41a0dc"     # background operation progress`;

const previewSnippet = `[preview.code]
bg = "none"                 # preview background; none = transparent
fg = "#d7e3f4"              # normal code text
line_number = "#7b90a7"     # gutter line numbers
line_highlight = "#151515"  # active/current line

comment = "#6f8399"         # comments
string = "#79e7d5"          # quoted strings
keyword = "#7aaeff"         # language keywords
function = "#36d7ff"        # function names
invalid = "#ff8585"         # invalid/error tokens`;

const classesSnippet = `[classes.directory]
icon = "󰉋"         # folder icon
color = "#5ba8ff"  # folder color

[classes.code]
icon = "󰆍"         # default code-file icon
color = "#38d5ff"  # default code-file color

[classes.config]
icon = "󰒓"         # default config-file icon
color = "#b38cff"  # default config-file color`;

const rulesSnippet = `[extensions.rs]
class = "code"     # reuse the code class
icon = ""         # Rust icon
color = "#dea584"  # Rust file color

[files."Cargo.toml"]
class = "config"   # exact filename override
icon = ""

[directories."node_modules"]
icon = "󰏗"         # exact directory-name override
color = "#6f7d8d"  # directory color`;
---

<DocsLayout
  title="elio docs: themes"
  description="Customize elio by creating a theme.toml file and overriding only what you need."
  currentPath="/docs/themes/"
  eyebrow="THEME"
  heading="Themes"
  lead="Customize elio by creating a theme.toml file and overriding only what you need."
>
  <section class="docs-section docs-section-first">
    <div class="docs-section-heading">
      <p class="eyebrow">THEME FILE</p>
      <h2 class="docs-section-title">Where theme.toml lives</h2>
      <p>Create <code>theme.toml</code> in your config directory. You only need to include the values you want to change.</p>
    </div>

    <article class="doc-card docs-card-tight docs-theme-path-card">
      <div class="docs-path-list">
        {
          themePaths.map((entry) => (
            <div class="docs-path-row">
              <span class="docs-path-platform">{entry.platform}</span>
              <span class="docs-path-values">
                <code set:html={formatPath(entry.primary)}></code>
                {entry.secondary && (
                  <>
                    <span class="docs-path-or">or</span>
                    <code set:html={formatPath(entry.secondary)}></code>
                  </>
                )}
              </span>
            </div>
          ))
        }
      </div>
    </article>
  </section>

  <section class="docs-section">
    <div class="docs-section-heading">
      <p class="eyebrow">THEME.TOML</p>
      <h2 class="docs-section-title">What goes in theme.toml</h2>
    </div>

    <article class="doc-card docs-detail-card docs-config-sections-card">
      <section class="docs-detail-block">
        <p class="docs-block-label">Sections</p>
        <ul class="docs-list docs-config-section-list">
          {
            themeSections.map((section) => (
              <li>
                <code>{section.name}</code>
                <span>{section.body}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </article>
  </section>

  <section class="docs-section">
    <div class="docs-section-heading">
      <p class="eyebrow">EXAMPLES</p>
      <h2 class="docs-section-title">Theme examples</h2>
      <p>Use these examples as a map for writing your own theme values.</p>
    </div>

    <div class="docs-config-examples">
      <article class="doc-card docs-card-tight docs-detail-card docs-config-example-card">
        <div class="docs-config-example-heading">
          <h3>Palette</h3>
        </div>

        <div class="command-block docs-config-code" data-command-block>
          <button class="command-copy" type="button" data-copy-command data-copy-state="idle" aria-label="Copy palette theme" title="Copy palette theme">
            <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
            <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
          </button>
          <pre class="language-toml"><code class="language-toml" set:html={highlightToml(paletteSnippet)}></code></pre>
        </div>

        <p class="docs-note docs-config-runtime-note">These colors control the main interface, from panels and text to selections and status markers.</p>
      </article>
      <article class="doc-card docs-card-tight docs-detail-card docs-config-example-card">
        <div class="docs-config-example-heading">
          <h3>Code previews</h3>
        </div>

        <div class="command-block docs-config-code" data-command-block>
          <button class="command-copy" type="button" data-copy-command data-copy-state="idle" aria-label="Copy code preview theme" title="Copy code preview theme">
            <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
            <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
          </button>
          <pre class="language-toml"><code class="language-toml" set:html={highlightToml(previewSnippet)}></code></pre>
        </div>

        <p class="docs-note docs-config-runtime-note">These colors only affect syntax-highlighted previews, not the file list or app chrome.</p>
      </article>

      <article class="doc-card docs-card-tight docs-detail-card docs-config-example-card">
        <div class="docs-config-example-heading">
          <h3>File classes</h3>
        </div>

        <div class="command-block docs-config-code" data-command-block>
          <button class="command-copy" type="button" data-copy-command data-copy-state="idle" aria-label="Copy file class theme" title="Copy file class theme">
            <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
            <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
          </button>
          <pre class="language-toml"><code class="language-toml" set:html={highlightToml(classesSnippet)}></code></pre>
        </div>

        <p class="docs-note docs-config-runtime-note">Classes are the default icon and color after elio detects the entry kind. Override a class when you want all files of that kind to change.</p>
        <div class="docs-config-pill-row docs-config-places-builtins" aria-label="Built-in file classes">
          {builtInClasses.map((item) => <code>{item}</code>)}
        </div>
      </article>

      <article class="doc-card docs-card-tight docs-detail-card docs-config-example-card">
        <div class="docs-config-example-heading">
          <h3>Extensions and exact names</h3>
        </div>

        <div class="command-block docs-config-code" data-command-block>
          <button class="command-copy" type="button" data-copy-command data-copy-state="idle" aria-label="Copy file matching theme" title="Copy file matching theme">
            <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
            <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
          </button>
          <pre class="language-toml"><code class="language-toml" set:html={highlightToml(rulesSnippet)}></code></pre>
        </div>

        <p class="docs-note docs-config-runtime-note">Use these for special cases. Exact file and directory names win over extensions; extensions win over class defaults. Matching is case-insensitive.</p>
      </article>

    </div>
  </section>

  <section class="docs-section">
    <div class="docs-two-up">
      <article class="doc-card docs-callout-card">
        <h3>Use the default theme as the full reference</h3>
        <p>Copy only the values you want to change. Missing keys keep the built-in defaults.</p>
        <a href="https://github.com/elio-fm/elio/blob/main/assets/themes/default/theme.toml" target="_blank" rel="noreferrer">View default/theme.toml</a>
      </article>

      <article class="doc-card docs-callout-card">
        <h3>Start from a bundled theme</h3>
        <p>Bundled themes show complete palettes and larger file-rule sets. Copy one when you want a full theme, not just a few overrides.</p>
        <a href="https://github.com/elio-fm/elio/tree/main/examples/themes" target="_blank" rel="noreferrer">Browse examples/themes</a>
      </article>
    </div>
  </section>

  <section class="docs-section">
    <div class="docs-section-heading">
      <p class="eyebrow">BUNDLED THEMES</p>
      <h2 class="docs-section-title">Bundled examples</h2>
      <p>Click a theme to open its source folder and copy its theme.toml.</p>
    </div>

    <div class="docs-theme-gallery" aria-label="Bundled theme examples">
      {
        themeShots.map((shot) => {
          const slug = themeSlug(shot.name);

          return (
            <a
              class="doc-card docs-theme-card"
              href={`https://github.com/elio-fm/elio/tree/main/examples/themes/${slug}`}
              target="_blank"
              rel="noreferrer"
            >
              <img src={shot.image} alt={`${shot.name} theme screenshot`} loading="lazy" width="1920" height="1080" />
              <span>{shot.name}</span>
            </a>
          );
        })
      }
    </div>
  </section>
</DocsLayout>
