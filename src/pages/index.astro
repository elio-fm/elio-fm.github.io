---
import BaseLayout from "../layouts/BaseLayout.astro";
import { actionPreviews, features, installOptions, themeShots } from "../data/site.js";
import { Check, ChevronLeft, ChevronRight, Command as CommandIcon, Copy, Image as ImageIcon, LayoutGrid, PanelsLeftRight, ScanEye, Trash2 } from "lucide-static";

const heroTitle = "elio";
const homeUrl = "https://elio-fm.github.io/";
const homeDescription = "Snappy terminal file manager (TUI) with three-pane layout, inline previews, rich previews, keyboard-first workflows, and trash support.";
const heroIntro = "Snappy, batteries-included terminal file manager with rich previews, inline images, bulk actions, and trash support";
const quickStartOptions = installOptions.map(({ name, quickStartLabel, command }) => ({
  name: quickStartLabel ?? name,
  command,
}));
const featureIcons = {
  panels: PanelsLeftRight,
  preview: ScanEye,
  image: ImageIcon,
  actions: CommandIcon,
  trash: Trash2,
  views: LayoutGrid,
};
const homeStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "elio",
  alternateName: "elio fm",
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "Linux, macOS, BSD",
  description: homeDescription,
  url: homeUrl,
  downloadUrl: `${homeUrl}install/`,
  softwareHelp: `${homeUrl}docs/`,
  codeRepository: "https://github.com/elio-fm/elio",
  image: `${homeUrl}images/logo.png`,
  screenshot: `${homeUrl}images/default.webp`,
  featureList: [
    "Three-pane layout",
    "Rich previews",
    "Inline image previews",
    "Keyboard-first workflows",
    "Copy, cut, and paste file actions",
  ],
};
---

<BaseLayout
  title="elio – Terminal File Manager with Rich Previews"
  ogTitle="elio – Terminal File Manager with Rich Previews"
  description={homeDescription}
  structuredData={homeStructuredData}
>
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-header">
            <div class="hero-lockup">
              <img class="hero-mark" src="/images/logo.png" alt="" width="88" height="88" />
              <h1>{heroTitle}</h1>
            </div>
          </div>

          <p class="hero-text">
            {heroIntro}
          </p>
        </div>

        <div class="hero-split">
          <div class="hero-shot frame" data-popout-item>
            <div class="frame-bar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="frame-body">
              <img
                src="/images/default.webp"
                alt="Default elio interface showing places, files, and preview panes."
                width="1920"
                height="1080"
                loading="eager"
              />
            </div>
          </div>

          <div class="quick-start hero-quick-start" data-quick-start>
            <div class="hero-quick-start-header">
              <h2>Quick start</h2>
              <p>Use your preferred package manager.</p>
            </div>

            <div class="quick-start-tabs" role="tablist" aria-label="Install methods">
              {
                quickStartOptions.map((option, index) => (
                  <button
                    class:list={["quick-start-tab", index === 0 && "is-active"]}
                    type="button"
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    data-command={option.command}
                  >
                    {option.name}
                  </button>
                ))
              }
            </div>

            <div class="quick-start-panel">
              <div class="command-block" data-command-block>
                <button
                  class="command-copy"
                  type="button"
                  data-copy-command
                  data-copy-state="idle"
                  aria-label="Copy command"
                  title="Copy command"
                >
                  <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                  <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
                </button>
                <pre><code data-quick-start-command>{quickStartOptions[0].command}</code></pre>
              </div>
              <a class="text-link" href="/install">Open full install page</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section motion-showcase">
    <div class="motion-showcase-shell">
      <div class="container motion-showcase-header">
        <div class="section-heading section-heading-centered motion-showcase-heading">
          <p class="eyebrow">DEMO</p>
          <h2>Watch elio at work</h2>
        </div>
      </div>

      <div class="motion-carousel-shell">
        <div class="motion-carousel-track" data-motion-track aria-label="elio workflow demos">
          {
            actionPreviews.map((preview) => (
              <figure class:list={["motion-demo", "frame", preview.id === "previews" && "motion-demo-featured"]} data-popout-item>
                <div class="frame-bar">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>

                <div class="motion-demo-body">
                  <video
                    class="motion-demo-video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-label={`${preview.label} workflow demo in elio`}
                  >
                    <source src={preview.video} type="video/webm" />
                  </video>
                </div>

                <figcaption class="motion-demo-caption">
                  <h3>{preview.title}</h3>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section feature-section section-tight-top">
    <div class="container">
      <div class="section-heading section-heading-centered feature-section-heading">
        <p class="eyebrow">FEATURES</p>
        <h2>Built for fast navigation</h2>
      </div>

      <div class="feature-grid">
        {
          features.map((feature) => (
            <article class="feature-card">
              <span class="feature-icon" aria-hidden="true" set:html={featureIcons[feature.icon]}></span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-tight-top themes-section">
    <div class="container">
      <div class="section-heading section-heading-centered">
        <p class="eyebrow">VISUALS</p>
        <h2>Bundled themes</h2>
      </div>

      <div class="visual-gallery" data-theme-gallery>
        <button
          class="visual-gallery-control visual-gallery-control-prev"
          type="button"
          aria-label="Previous theme"
          data-theme-scroll="previous"
        >
          <span aria-hidden="true" set:html={ChevronLeft}></span>
        </button>

        <div class="visual-carousel-shell" tabindex="0" aria-label="Bundled theme screenshots" data-theme-carousel>
          <div class="visual-track">
          {
            themeShots.map((shot) => (
              <figure class="shot-card" data-popout-item>
                <div class="shot-card-image">
                  <img src={shot.image} alt="" loading="lazy" width="1920" height="1080" />
                </div>
                <figcaption>{shot.name}</figcaption>
              </figure>
            ))
          }
          </div>
        </div>

        <button
          class="visual-gallery-control visual-gallery-control-next"
          type="button"
          aria-label="Next theme"
          data-theme-scroll="next"
        >
          <span aria-hidden="true" set:html={ChevronRight}></span>
        </button>
      </div>
    </div>
  </section>

  <script>
    const root = document.querySelector("[data-quick-start]");
    if (root) {
      const tabs = Array.from(root.querySelectorAll(".quick-start-tab"));
      const command = root.querySelector("[data-quick-start-command]");
      const copyButton = root.querySelector("[data-copy-command]");

      const selectTab = (activeTab) => {
        tabs.forEach((tab) => {
          const isActive = tab === activeTab;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        if (command) {
          command.textContent = activeTab.dataset.command ?? "";
        }

        if (copyButton) {
          copyButton.dataset.copyState = "idle";
          copyButton.setAttribute("aria-label", "Copy command");
          copyButton.setAttribute("title", "Copy command");
        }
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => selectTab(tab));
      });
    }

    const motionTrack = document.querySelector("[data-motion-track]");
    if (motionTrack instanceof HTMLElement) {
      motionTrack.addEventListener(
        "wheel",
        (event) => {
          if (event.ctrlKey) {
            return;
          }

          if (event.shiftKey) {
            if (motionTrack.scrollWidth <= motionTrack.clientWidth + 1) {
              return;
            }

            event.preventDefault();
            motionTrack.scrollBy({
              left: (Math.abs(event.deltaX) > 0 ? event.deltaX : event.deltaY) * 1.35,
              behavior: "auto",
            });
            return;
          }
        },
        { passive: false },
      );
    }

    const themeCarousel = document.querySelector("[data-theme-carousel]");
    if (themeCarousel instanceof HTMLElement) {
      const themeGallery = themeCarousel.closest("[data-theme-gallery]");
      const themeTrack = themeCarousel.querySelector(".visual-track");
      const scrollButtons = themeGallery
        ? Array.from(themeGallery.querySelectorAll("[data-theme-scroll]"))
        : [];

      const getThemeScrollStep = () => {
        const firstCard = themeCarousel.querySelector(".shot-card");
        if (!(firstCard instanceof HTMLElement)) {
          return Math.max(320, themeCarousel.clientWidth * 0.75);
        }

        const gap = themeTrack instanceof HTMLElement ? parseFloat(getComputedStyle(themeTrack).columnGap || "0") : 0;
        return firstCard.offsetWidth + (Number.isFinite(gap) ? gap : 0);
      };

      const updateThemeControls = () => {
        const maxScroll = themeCarousel.scrollWidth - themeCarousel.clientWidth;
        const atStart = maxScroll <= 1 || themeCarousel.scrollLeft <= 1;
        const atEnd = maxScroll <= 1 || themeCarousel.scrollLeft >= maxScroll - 1;

        themeCarousel.dataset.scrollStart = atStart ? "true" : "false";
        themeCarousel.dataset.scrollEnd = atEnd ? "true" : "false";

        scrollButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          const direction = button.dataset.themeScroll;
          const disabled = direction === "previous" ? atStart : atEnd;

          button.disabled = disabled;
        });
      };

      const scrollThemes = (direction) => {
        themeCarousel.scrollBy({
          left: direction * getThemeScrollStep(),
          behavior: "smooth",
        });
      };

      scrollButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const direction = button.dataset.themeScroll === "previous" ? -1 : 1;
          scrollThemes(direction);
        });
      });

      themeCarousel.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollThemes(-1);
        }

        if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollThemes(1);
        }

        if (event.key === "Home") {
          event.preventDefault();
          themeCarousel.scrollTo({ left: 0, behavior: "smooth" });
        }

        if (event.key === "End") {
          event.preventDefault();
          themeCarousel.scrollTo({ left: themeCarousel.scrollWidth, behavior: "smooth" });
        }
      });

      themeCarousel.addEventListener("scroll", updateThemeControls, { passive: true });
      window.addEventListener("resize", updateThemeControls);
      updateThemeControls();
    }

  </script>
</BaseLayout>
