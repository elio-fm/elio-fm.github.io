---
import BaseLayout from "../layouts/BaseLayout.astro";
import { actionPreviews, features, installOptions, themeShots } from "../data/site.js";
import { Check, Command as CommandIcon, Copy, Image as ImageIcon, LayoutGrid, PanelsLeftRight, ScanEye, Trash2 } from "lucide-static";

const heroTitle = "elio";
const quickStartOptions = installOptions.map(({ name, command }) => ({ name, command }));
const featureIcons = {
  panels: PanelsLeftRight,
  preview: ScanEye,
  image: ImageIcon,
  actions: CommandIcon,
  trash: Trash2,
  views: LayoutGrid,
};
---

<BaseLayout
  title="elio | Terminal File Manager"
  description="A terminal-native file manager with a three-pane layout, rich previews, and inline images."
>
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-header">
            <div class="hero-lockup">
              <img class="hero-mark" src="/images/logo.png" alt="" width="88" height="88" />
              <h1>{heroTitle}</h1>
            </div>
          </div>

          <p class="hero-text">
            A three-pane terminal file manager with rich previews, inline images, and quick actions for fast file workflows.
          </p>
        </div>

        <div class="hero-split">
          <div class="hero-shot frame">
            <div class="frame-bar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="frame-body">
              <img
                src="/images/default.webp"
                alt="Default elio interface showing places, files, and preview panes."
                width="1425"
                loading="eager"
              />
            </div>
          </div>

          <div class="quick-start hero-quick-start" data-quick-start>
            <div class="hero-quick-start-header">
              <h2>Quick start</h2>
              <p>Use your preferred package manager.</p>
            </div>

            <div class="quick-start-tabs" role="tablist" aria-label="Install methods">
              {
                quickStartOptions.map((option, index) => (
                  <button
                    class:list={["quick-start-tab", index === 0 && "is-active"]}
                    type="button"
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    data-command={option.command}
                  >
                    {option.name}
                  </button>
                ))
              }
            </div>

            <div class="quick-start-panel">
              <div class="command-block" data-command-block>
                <button
                  class="command-copy"
                  type="button"
                  data-copy-command
                  data-copy-state="idle"
                  aria-label="Copy command"
                  title="Copy command"
                >
                  <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                  <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
                </button>
                <pre><code data-quick-start-command>{quickStartOptions[0].command}</code></pre>
              </div>
              <a class="text-link" href="/install">Open full install page</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section motion-showcase">
    <div class="motion-showcase-shell">
      <div class="container motion-showcase-header">
        <div class="section-heading section-heading-centered motion-showcase-heading">
          <p class="eyebrow">DEMO</p>
          <h2>See elio in motion</h2>
          <p>Real workflow clips from inside elio.</p>
        </div>
      </div>

      <div class="motion-carousel-shell">
        <div class="motion-carousel-track" data-motion-track aria-label="elio workflow demos">
          {
            actionPreviews.map((preview) => (
              <figure class:list={["motion-demo", "frame", preview.id === "previews" && "motion-demo-featured"]}>
                <div class="frame-bar">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>

                <div class="motion-demo-body">
                  <video
                    class="motion-demo-video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-label={`${preview.label} workflow demo in elio`}
                  >
                    <source src={preview.video} type="video/webm" />
                  </video>
                </div>

                <figcaption class="motion-demo-caption">
                  <h3>{preview.title}</h3>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading section-heading-centered">
        <p class="eyebrow">FEATURES</p>
        <h2>Built for fast navigation</h2>
      </div>

      <div class="feature-grid">
        {
          features.map((feature) => (
            <article class="feature-card">
              <span class="feature-icon" aria-hidden="true" set:html={featureIcons[feature.icon]}></span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading section-heading-centered">
        <p class="eyebrow">VISUALS</p>
        <h2>Bundled themes</h2>
        <p>
          Different palettes, same readable layout.
        </p>
      </div>

      <div class="visual-grid">
        {
          themeShots.map((shot) => (
            <figure class="shot-card">
              <img src={shot.image} alt={shot.alt} loading="lazy" />
              <figcaption>{shot.name}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const root = document.querySelector("[data-quick-start]");
    if (root) {
      const tabs = Array.from(root.querySelectorAll(".quick-start-tab"));
      const command = root.querySelector("[data-quick-start-command]");
      const copyButton = root.querySelector("[data-copy-command]");

      const selectTab = (activeTab) => {
        tabs.forEach((tab) => {
          const isActive = tab === activeTab;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        if (command) {
          command.textContent = activeTab.dataset.command ?? "";
        }

        if (copyButton) {
          copyButton.dataset.copyState = "idle";
          copyButton.setAttribute("aria-label", "Copy command");
          copyButton.setAttribute("title", "Copy command");
        }
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => selectTab(tab));
      });
    }

    const motionTrack = document.querySelector("[data-motion-track]");
    if (motionTrack instanceof HTMLElement) {
      motionTrack.addEventListener(
        "wheel",
        (event) => {
          if (event.ctrlKey) {
            return;
          }

          if (event.shiftKey) {
            if (motionTrack.scrollWidth <= motionTrack.clientWidth + 1) {
              return;
            }

            event.preventDefault();
            motionTrack.scrollBy({
              left: (Math.abs(event.deltaX) > 0 ? event.deltaX : event.deltaY) * 1.35,
              behavior: "auto",
            });
            return;
          }
        },
        { passive: false },
      );
    }
  </script>
</BaseLayout>
