---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prism from "prismjs";
import "prismjs/components/prism-bash.js";
import { installOptions } from "../../data/site.js";
import { siArchlinux, siDebian, siFedora, siHomebrew, siRust } from "simple-icons";
import { Check, Copy } from "lucide-static";

const highlightBash = (code) => Prism.highlight(code, Prism.languages.bash, "bash");

const formatInstallIcon = (svg) =>
  svg
    .replace(/<title>.*?<\/title>/, "")
    .replace("<svg ", '<svg focusable="false" aria-hidden="true" preserveAspectRatio="xMidYMid meet" ');

const installIcons = {
  archlinux: formatInstallIcon(siArchlinux.svg),
  debian: formatInstallIcon(siDebian.svg),
  fedora: formatInstallIcon(siFedora.svg),
  homebrew: formatInstallIcon(siHomebrew.svg),
  rust: formatInstallIcon(siRust.svg),
};

---

<BaseLayout
  title="Install elio"
  description="Install elio with apt, Homebrew, AUR, Fedora COPR, or Cargo, then add optional tools if needed."
>
  <section class="page-intro page-intro-compact">
    <div class="container">
      <div class="page-lead">
      <p class="eyebrow">INSTALL</p>
      <h1>Install elio</h1>
      <p>
        Use your preferred package manager.
      </p>
      </div>
    </div>
  </section>

  <section class="section section-tight-top">
    <div class="container">
      <div class="install-page-grid">
        <div class="install-list">
          {
            installOptions.map((option) => (
              <article class="install-card">
                <div class="install-topline">
                  <h2 class="install-title">
                    <span class={`install-icon install-icon--${option.icon}`} aria-hidden="true">
                      <span class="install-icon-mark" set:html={installIcons[option.icon]}></span>
                    </span>
                    <span>{option.name}</span>
                  </h2>
                  <p>{option.note}</p>
                </div>
                {option.manualCommand && (
                  <p class="install-tooling-label install-command-label">Option 1 — Quick install</p>
                )}
                <div class="command-block" data-command-block>
                  <button
                    class="command-copy"
                    type="button"
                    data-copy-command
                    data-copy-state="idle"
                    aria-label="Copy command"
                    title="Copy command"
                  >
                    <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                    <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
                  </button>
                  <pre class="language-bash"><code class="language-bash" set:html={highlightBash(option.command)}></code></pre>
                </div>
                {
                  option.manualCommand && (
                    <div class="install-tooling">
                      <p class="install-tooling-label">Option 2 — Manual setup</p>
                      <div class="command-block" data-command-block>
                        <button
                          class="command-copy"
                          type="button"
                          data-copy-command
                          data-copy-state="idle"
                          aria-label="Copy command"
                          title="Copy command"
                        >
                          <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                          <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
                        </button>
                        <pre class="language-bash"><code class="language-bash" set:html={highlightBash(option.manualCommand)}></code></pre>
                      </div>
                    </div>
                  )
                }
                {
                  option.optionalToolsCommand && (
                    <div class="install-tooling">
                      <p class="install-tooling-label">Optional preview tools</p>
                      <div class="command-block" data-command-block>
                        <button
                          class="command-copy"
                          type="button"
                          data-copy-command
                          data-copy-state="idle"
                          aria-label="Copy command"
                          title="Copy command"
                        >
                          <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                          <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
                        </button>
                        <pre class="language-bash"><code class="language-bash" set:html={highlightBash(option.optionalToolsCommand)}></code></pre>
                      </div>
                      {option.optionalToolsNote && <p class="install-tooling-note">{option.optionalToolsNote}</p>}
                    </div>
                  )
                }
              </article>
            ))
          }
        </div>

        <aside class="install-aside">
          <article class="doc-card">
            <h2>Optional preview tools</h2>
            <p>
              <code>elio</code> works out of the box. Install optional tools for richer previews,
              metadata, thumbnails, and broader file format support.
            </p>
            <ul class="install-tool-list" aria-label="Optional preview tools">
              <li>
                <strong>Poppler</strong>
                <span>PDF metadata and rendered page previews.</span>
              </li>
              <li>
                <strong>FFmpeg</strong>
                <span>Media metadata, album art, thumbnails, and wider image format support.</span>
              </li>
              <li>
                <strong>resvg</strong>
                <span>SVG inline previews.</span>
              </li>
              <li>
                <strong>7-Zip</strong>
                <span>Comic book archives, fallback archive listings, and broader archive support.</span>
              </li>
            </ul>
            <p><a href="/docs/optional-tools/">View optional tools guide</a></p>
          </article>

          <article class="doc-card">
            <h2>Nerd Font</h2>
            <p>Use a Nerd Font in your terminal so icons render correctly.</p>
          </article>

          <article class="doc-card">
            <h2>zoxide integration</h2>
            <p>
              Install <code>zoxide</code> if you want <code>z</code> jumps based on your directory history.
            </p>
          </article>

          <article class="doc-card">
            <h2>Running from source</h2>
            <p>Clone the repo, then run elio from the project directory.</p>
            <div class="command-block" data-command-block>
              <button
                class="command-copy"
                type="button"
                data-copy-command
                data-copy-state="idle"
                aria-label="Copy command"
                title="Copy command"
              >
                <span class="command-copy-icon" data-copy-icon="copy" aria-hidden="true" set:html={Copy}></span>
                <span class="command-copy-icon" data-copy-icon="check" aria-hidden="true" set:html={Check}></span>
              </button>
              <pre class="language-bash"><code class="language-bash" set:html={highlightBash(`git clone https://github.com/elio-fm/elio.git
cd elio
cargo run --release`)}></code></pre>
            </div>
          </article>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
