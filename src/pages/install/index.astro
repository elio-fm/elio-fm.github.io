---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { installOptions } from "../../data/site.js";
import { siArchlinux, siFedora, siRust } from "simple-icons";
import { Beer } from "lucide-static";

const installIcons = {
  archlinux: {
    viewBox: siArchlinux.svg.match(/viewBox="([^"]+)"/)?.[1] ?? "0 0 24 24",
    path: siArchlinux.path,
    transform: "translate(1.2 1.05) scale(0.89)",
  },
  fedora: {
    viewBox: siFedora.svg.match(/viewBox="([^"]+)"/)?.[1] ?? "0 0 24 24",
    path: siFedora.path,
    transform: "translate(1.15 0.9) scale(0.88)",
  },
  rust: {
    viewBox: siRust.svg.match(/viewBox="([^"]+)"/)?.[1] ?? "0 0 24 24",
    path: siRust.path,
    transform: "translate(1.05 1.05) scale(0.88)",
  },
};
---

<BaseLayout
  title="Install Elio"
  description="Install Elio with Homebrew, AUR, Fedora COPR, or Cargo."
>
  <section class="page-intro page-intro-compact">
    <div class="container">
      <div class="page-lead">
      <p class="eyebrow">INSTALL</p>
      <h1>Install Elio.</h1>
      <p>
        Pick the package manager you already use. Elio starts in your current working directory,
        and a Nerd Font is recommended so icons render correctly.
      </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="install-page-grid">
        <div class="install-list">
          {
            installOptions.map((option) => (
              <article class="install-card">
                <div class="install-topline">
                  <h2 class="install-title">
                    <span class="install-icon" aria-hidden="true">
                      {
                        option.icon === "homebrew" ? (
                          <span class="install-icon-mark install-icon-mark-stroke" set:html={Beer}></span>
                        ) : (
                          <svg
                            class="install-icon-mark"
                            viewBox={installIcons[option.icon].viewBox}
                            width="18"
                            height="18"
                            focusable="false"
                            fill="currentColor"
                          >
                            <path d={installIcons[option.icon].path} transform={installIcons[option.icon].transform}></path>
                          </svg>
                        )
                      }
                    </span>
                    <span>{option.name}</span>
                  </h2>
                  <p>{option.note}</p>
                </div>
                <pre><code>{option.command}</code></pre>
              </article>
            ))
          }
        </div>

        <aside class="install-aside">
          <article class="doc-card">
            <h2>Notes</h2>
            <p>Elio starts in your current working directory.</p>
            <p>Use a Nerd Font in your terminal so icons display correctly.</p>
          </article>

          <article class="doc-card">
            <h2>From source</h2>
            <pre><code>cargo run --release</code></pre>
          </article>

          <article class="doc-card">
            <h2>Need more detail?</h2>
            <p>
              Configuration and theming live in the docs. The full project reference lives in the
              main repository.
            </p>
            <p><a href="/docs">Open docs</a></p>
            <p>
              <a href="https://github.com/elio-fm/elio#readme" target="_blank" rel="noreferrer">
                Read the README
              </a>
            </p>
          </article>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
