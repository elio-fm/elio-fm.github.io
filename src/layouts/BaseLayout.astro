---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "elio",
  ogTitle = title,
  ogSiteName = "elio fm",
  description = "elio is a terminal file manager (TUI) with a three-pane layout, rich previews, and inline image previews.",
  structuredData = null,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const ogImage = new URL("/images/default.webp", Astro.site ?? Astro.url).toString();
const socialImageAlt = "elio terminal file manager interface with three panes and inline preview.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      const setCopyState = (button, state) => {
        button.dataset.copyState = state;
        const label = state === "copied" ? "Copied" : state === "error" ? "Copy failed" : "Copy command";
        button.setAttribute("aria-label", label);
        button.setAttribute("title", label);
      };

      const fallbackCopy = (text) => {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "absolute";
        textarea.style.left = "-9999px";
        document.body.appendChild(textarea);
        textarea.select();
        const copied = document.execCommand("copy");
        document.body.removeChild(textarea);
        return copied;
      };

      document.addEventListener("click", async (event) => {
        const button = event.target.closest("[data-copy-command]");
        if (!(button instanceof HTMLButtonElement)) return;

        const block = button.closest("[data-command-block]");
        const code = block?.querySelector("code");
        const text = code?.textContent?.trimEnd();

        if (!text) return;

        let copied = false;

        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            copied = true;
          } else {
            copied = fallbackCopy(text);
          }
        } catch {
          copied = fallbackCopy(text);
        }

        setCopyState(button, copied ? "copied" : "error");
        window.clearTimeout(button.__copyResetTimer);
        button.__copyResetTimer = window.setTimeout(() => setCopyState(button, "idle"), copied ? 1600 : 2200);
      });

      const mediaPopoutQuery = window.matchMedia("(min-width: 900px) and (hover: hover) and (pointer: fine)");
      let activeMediaPopout = null;

      const popoutItems = () => [...document.querySelectorAll("[data-popout-item]")];

      const syncPopoutControls = () => {
        popoutItems().forEach((item) => {
          if (mediaPopoutQuery.matches) {
            const title =
              item.querySelector("h3, figcaption")?.textContent?.trim() ||
              item.querySelector("img")?.getAttribute("alt") ||
              "preview";
            item.setAttribute("role", "button");
            item.setAttribute("tabindex", "0");
            item.setAttribute("aria-label", `Open ${title}`);
          } else {
            item.removeAttribute("role");
            item.removeAttribute("tabindex");
            item.removeAttribute("aria-label");
          }
        });
      };

      const closePopout = () => {
        if (!activeMediaPopout) return;

        const { source, overlay, clone, previousBodyOverflow, previousBodyPaddingRight } = activeMediaPopout;
        const sourceRect = source.getBoundingClientRect();
        activeMediaPopout = null;

        overlay.classList.add("is-closing");
        overlay.classList.remove("is-open");
        clone.style.left = `${sourceRect.left}px`;
        clone.style.top = `${sourceRect.top}px`;
        clone.style.width = `${sourceRect.width}px`;

        window.setTimeout(() => {
          source.classList.remove("is-popout-source");
          document.body.style.overflow = previousBodyOverflow;
          document.body.style.paddingRight = previousBodyPaddingRight;
          window.requestAnimationFrame(() => overlay.remove());
        }, 220);
      };

      const openPopout = (source) => {
        if (!mediaPopoutQuery.matches || activeMediaPopout) return;

        const sourceRect = source.getBoundingClientRect();
        const overlay = document.createElement("div");
        const backdrop = document.createElement("div");
        const clone = source.cloneNode(true);

        overlay.className = "media-popout";
        overlay.setAttribute("role", "dialog");
        overlay.setAttribute("aria-modal", "true");
        backdrop.className = "media-popout-backdrop";
        clone.classList.add("media-popout-card");
        clone.classList.remove("is-popout-source");
        clone.removeAttribute("data-popout-item");
        clone.removeAttribute("role");
        clone.removeAttribute("tabindex");
        clone.removeAttribute("aria-label");
        clone.style.left = `${sourceRect.left}px`;
        clone.style.top = `${sourceRect.top}px`;
        clone.style.width = `${sourceRect.width}px`;

        overlay.append(backdrop, clone);
        document.body.append(overlay);
        const previousBodyOverflow = document.body.style.overflow;
        const previousBodyPaddingRight = document.body.style.paddingRight;
        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        if (scrollbarWidth > 0) {
          document.body.style.paddingRight = `${scrollbarWidth}px`;
        }
        document.body.style.overflow = "hidden";
        source.classList.add("is-popout-source");
        activeMediaPopout = { source, overlay, clone, previousBodyOverflow, previousBodyPaddingRight };

        const video = clone.querySelector("video");
        if (video instanceof HTMLVideoElement) {
          video.muted = true;
          video.play().catch(() => {});
        }

        window.requestAnimationFrame(() => {
          const sourceRatio = sourceRect.height / sourceRect.width;
          let targetWidth = Math.min(window.innerWidth - 80, 1040);
          let targetHeight = targetWidth * sourceRatio;

          if (targetHeight > window.innerHeight - 80) {
            targetHeight = window.innerHeight - 80;
            targetWidth = targetHeight / sourceRatio;
          }

          overlay.classList.add("is-open");
          clone.style.left = `${(window.innerWidth - targetWidth) / 2}px`;
          clone.style.top = `${(window.innerHeight - targetHeight) / 2}px`;
          clone.style.width = `${targetWidth}px`;
        });
      };

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (activeMediaPopout) {
          if (target.closest(".media-popout-card")) return;
          if (target.closest(".media-popout")) closePopout();
          return;
        }

        const item = target.closest("[data-popout-item]");
        if (!item) return;

        openPopout(item);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closePopout();
          return;
        }

        if (event.key !== "Enter" && event.key !== " ") return;

        const item = document.activeElement?.closest?.("[data-popout-item]");
        if (!item) return;

        event.preventDefault();
        openPopout(item);
      });

      mediaPopoutQuery.addEventListener("change", () => {
        syncPopoutControls();
        if (!mediaPopoutQuery.matches) closePopout();
      });

      window.addEventListener("resize", () => {
        if (!mediaPopoutQuery.matches) closePopout();
      });

      syncPopoutControls();
    </script>
  </body>
</html>
